# Immich Environment Configuration
# Documentation: https://docs.immich.app/install/environment-variables

# The location where your uploaded files are stored
UPLOAD_LOCATION=./library

# The location where your database files are stored
# Network shares are NOT supported for the database
DB_DATA_LOCATION=./postgres

# Timezone (Czech Republic)
# Uncomment and change if needed: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Prague

# The Immich version to use
# You can pin this to a specific version like "v2.1.0" or use "release" for latest stable
IMMICH_VERSION=release

# PostgreSQL password
# Override this in Coolify environment variables!
DB_PASSWORD=postgres

# Database configuration (no need to change these)
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
